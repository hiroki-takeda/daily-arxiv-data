prefix_rule(
    pattern = ["node", "scripts/publish-edition.mjs"],
    decision = "forbidden",
    justification = "Write only the host-provided staging reports and manifest; the host publishes after Codex exits.",
    match = [
        "node scripts/publish-edition.mjs 2026-07-13 /tmp/daily-arxiv/staging",
    ],
)

prefix_rule(
    pattern = ["npm", "run", "publish"],
    decision = "forbidden",
    justification = "The host publisher runs only after the model exits and its manifest is validated.",
    match = ["npm run publish -- 2026-07-13 /tmp/daily-arxiv/staging"],
)

prefix_rule(
    pattern = ["git"],
    decision = "forbidden",
    justification = "The model performs no Git operation; the host owns worktree sync, validation, commit, and push.",
    match = ["git status"],
)

prefix_rule(
    pattern = ["/usr/bin/git"],
    decision = "forbidden",
    justification = "Absolute-path Git bypasses are also forbidden inside the model stage.",
    match = ["/usr/bin/git status"],
)
